{
    "name": "yusufgenc/filament-api-forge",
    "version": "1.2.0",
    "description": "Automatically expose your Filament Resources as fully-featured REST APIs with authentication, documentation, rate limiting and query builder support.",
    "keywords": [
        "filament",
        "filament-plugin",
        "laravel",
        "api",
        "rest",
        "openapi",
        "query-builder"
    ],
    "homepage": "https://github.com/yusufgenc34/filament-api-forge",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Yusuf Genc",
            "email": "theyusufgenc@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16",
        "spatie/laravel-query-builder": "^5.0|^6.0"
    },
    "suggest": {
        "spatie/laravel-medialibrary": "Required for file/media upload support in API endpoints via Spatie Media Library."
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "YusufGenc34\\FilamentApiForge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YusufGenc34\\FilamentApiForge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "YusufGenc34\\FilamentApiForge\\FilamentApiForgeServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
